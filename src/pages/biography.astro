---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import bioRaw from '../data/biography.md?raw';

const sections = bioRaw.split(/\n---\n/);
const jaText = sections[0].trim();
const enParagraphs = sections[1]?.trim().split(/\n\n/) ?? [];
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`Biography | ${SITE_TITLE}`} description="in the blue shirt - biography" />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title animate-in">Biography</h1>
			<p class="page-subtitle animate-in">About the artist</p>

			<img src="/photo-artist.jpg" alt="Ryo Arimura" class="bio-photo animate-in" style="animation-delay: 0.1s" />

			<div class="bio-content animate-in" style="animation-delay: 0.15s">
				<div class="bio-name">
					<span class="name-en">Ryo Arimura</span>
					<span class="name-ja">有村 崚</span>
				</div>

				<div class="bio-text">
					<p>{jaText}</p>
				</div>

				<hr />

				<div class="bio-text bio-en">
					{enParagraphs.map((p: string) => <p>{p}</p>)}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.bio-photo {
		display: block;
		width: 100%;
		max-width: 640px;
		border-radius: var(--radius-lg);
		margin: 0 auto 2.5em;
	}
	.bio-content {
		max-width: 640px;
		margin: 0 auto;
	}
	.bio-name {
		display: flex;
		align-items: baseline;
		gap: 0.8em;
		margin-bottom: 2em;
	}
	.name-en {
		font-size: 1.6em;
		font-weight: 700;
		letter-spacing: -0.02em;
	}
	.name-ja {
		font-size: 1em;
		color: var(--text-light);
	}
	.bio-text {
		line-height: 2;
	}
	.bio-text p {
		margin-bottom: 1em;
	}
	.bio-en {
		color: var(--text-light);
	}
	hr {
		margin: 2em 0;
	}
</style>
