---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`Release | ${SITE_TITLE}`} description="in the blue shirt - discography" />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title animate-in">Release</h1>
			<p class="page-subtitle animate-in">Discography</p>

			<div class="release-grid">
				{releases.map((r, i) => (
					<div class="release-card animate-in" style={`animation-delay: ${0.05 + i * 0.05}s`}>
						{r.image && (
							<a href={r.bandcamp} target="_blank" rel="noopener" class="release-image">
								<img src={r.image} alt={r.title} loading="lazy" />
							</a>
						)}
						<div class="release-detail">
						<div class="release-header">
							<span class="release-year">{r.year}</span>
							<span class="badge badge-blue">{r.type}</span>
						</div>
						<h2 class="release-title">{r.title}</h2>
						{r.tracks && r.tracks.length > 0 && (
							<ol class="track-list">
								{r.tracks.map((t) => <li>{t}</li>)}
							</ol>
						)}
						<div class="release-links">
							{r.bandcamp && <a href={r.bandcamp} target="_blank" rel="noopener">Bandcamp</a>}
						</div>
						</div>
					</div>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.release-grid {
		display: grid;
		gap: 2em;
	}
	.release-card {
		display: grid;
		grid-template-columns: 180px 1fr;
		gap: 1.5em;
		border: 1px solid var(--border);
		border-radius: var(--radius-lg);
		padding: 1.5em;
		transition: all 0.25s ease;
	}
	.release-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-2px);
	}
	.release-image {
		display: block;
	}
	.release-image img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		border-radius: var(--radius);
	}
	.release-detail {
		min-width: 0;
	}
	.release-header {
		display: flex;
		align-items: center;
		gap: 0.8em;
		margin-bottom: 0.5em;
	}
	.release-year {
		font-size: 0.85em;
		color: var(--text-light);
	}
	.release-title {
		font-size: 1.3em;
		margin-bottom: 0.3em;
		letter-spacing: -0.01em;
	}
	.track-list {
		font-size: 0.8em;
		color: var(--text-light);
		margin: 0 0 1em;
		padding-left: 1.5em;
		line-height: 1.7;
	}
	.track-list li {
		padding-left: 0.2em;
	}
	.release-links {
		display: flex;
		gap: 0.6em;
		flex-wrap: wrap;
	}
	.release-links a {
		display: inline-block;
		padding: 0.4em 1em;
		border: 1.5px solid var(--border);
		border-radius: 999px;
		font-size: 0.8em;
		color: var(--text);
		text-decoration: none;
		transition: all 0.2s ease;
	}
	.release-links a:hover {
		border-color: var(--accent);
		color: var(--accent);
		background: #e6f3fb;
	}
	/* Cards without image: full width detail */
	.release-card:not(:has(.release-image)) {
		grid-template-columns: 1fr;
	}
	@media (max-width: 640px) {
		.release-card {
			grid-template-columns: 120px 1fr;
		}
		.release-title {
			font-size: 1.1em;
		}
	}
	@media (max-width: 480px) {
		.release-card {
			grid-template-columns: 1fr;
		}
	}
</style>
