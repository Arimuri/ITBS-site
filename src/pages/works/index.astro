---
import { getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('works')).sort((a, b) => {
	const dateA = (b.data.pubDate ?? b.data.date)?.valueOf() ?? 0;
	const dateB = (a.data.pubDate ?? a.data.date)?.valueOf() ?? 0;
	return dateA - dateB;
});

// Render all posts
const rendered = await Promise.all(
	posts.map(async (post) => {
		const { Content } = await render(post);
		return { post, Content };
	})
);

// Extract YouTube embed URL from post body
function getYouTubeId(body: string): string | null {
	const match = body.match(/youtube\.com\/embed\/([a-zA-Z0-9_-]+)/)
		?? body.match(/youtube\.com\/watch\?v=([a-zA-Z0-9_-]+)/)
		?? body.match(/youtu\.be\/([a-zA-Z0-9_-]+)/);
	return match ? match[1] : null;
}
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`Works | ${SITE_TITLE}`} description="in the blue shirt - works" />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title animate-in">Works</h1>

			<div class="works-list">
				{rendered.map(({ post, Content }, i) => {
					const ytId = getYouTubeId(post.body ?? '');
					return (
						<article class="works-item animate-in" style={`animation-delay: ${0.03 + i * 0.02}s`}>
							<div class="works-header">
								<h2 class="works-title">{post.data.title}</h2>
								<p class="works-date">
									<FormattedDate date={post.data.pubDate ?? post.data.date} />
								</p>
							</div>
							{ytId && (
								<div class="works-video">
									<iframe
										src={`https://www.youtube.com/embed/${ytId}`}
										title={post.data.title ?? ''}
										allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
										allowfullscreen
										loading="lazy"
									/>
								</div>
							)}
							<div class="works-body">
								<Content />
							</div>
						</article>
					);
				})}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.works-list {
		display: grid;
		gap: 3em;
	}
	.works-item {
		border-bottom: 1px solid var(--border-light);
		padding-bottom: 3em;
	}
	.works-item:last-child {
		border-bottom: none;
	}
	.works-header {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1em;
		margin-bottom: 1em;
	}
	.works-title {
		font-size: 1.15em;
		margin: 0;
	}
	.works-date {
		font-size: 0.8em;
		color: var(--text-light);
		margin: 0;
		white-space: nowrap;
	}
	.works-video {
		position: relative;
		width: 100%;
		padding-bottom: 56.25%;
		margin-bottom: 1em;
		border-radius: var(--radius);
		overflow: hidden;
		background: #000;
	}
	.works-video iframe {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		border: none;
	}
	.works-body {
		line-height: 1.8;
		font-size: 0.95em;
		color: var(--text);
	}
	.works-body :global(p) {
		margin-bottom: 0.8em;
	}
	.works-body :global(img) {
		border-radius: var(--radius);
		margin: 1em 0;
	}
	.works-body :global(iframe),
	.works-body :global(.embed-youtube) {
		display: none;
	}
	@media (max-width: 640px) {
		.works-header {
			flex-direction: column;
			gap: 0.3em;
		}
	}
</style>
