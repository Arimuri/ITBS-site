---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`Contact | ${SITE_TITLE}`} description="in the blue shirt - contact" />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title animate-in">Contact</h1>
			<p class="page-subtitle animate-in">お問い合わせ</p>

			<div class="budget-link animate-in" style="animation-delay: 0.05s">
				<a href="/budget">お仕事依頼 予算ガイドライン →</a>
			</div>

			<div class="form-wrap animate-in" style="animation-delay: 0.1s">
				<iframe
					src="https://docs.google.com/forms/d/e/1FAIpQLScmBZi12zvwHZmWMDbsTRstEzhxax4owqx6TIZ71texDIMuXg/viewform?embedded=true"
					width="100%"
					height="923"
					frameborder="0"
					marginheight="0"
					marginwidth="0"
					loading="lazy"
				>読み込んでいます…</iframe>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.form-wrap {
		max-width: 640px;
		margin: 0 auto;
	}
	.budget-link {
		max-width: 640px;
		margin: 0 auto 2em;
	}
	.budget-link a {
		display: inline-block;
		padding: 0.6em 1.4em;
		background: var(--bg-soft);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		font-size: 0.85em;
		font-weight: 500;
		color: var(--text);
		transition: all 0.2s ease;
	}
	.budget-link a:hover {
		background: var(--accent);
		color: #fff;
		border-color: var(--accent);
		transform: translateY(-1px);
		box-shadow: var(--shadow-sm);
	}
	.form-wrap iframe {
		border: none;
		border-radius: var(--radius);
	}
</style>
