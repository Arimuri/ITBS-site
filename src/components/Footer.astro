---
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="footer-links">
			<a href="https://twitter.com/intheblueshirt" target="_blank" rel="noopener">Twitter</a>
			<a href="https://www.instagram.com/intheblueshirt/" target="_blank" rel="noopener">Instagram</a>
			<a href="https://www.youtube.com/@intheblueshirt" target="_blank" rel="noopener">YouTube</a>
			<a href="https://intheblueshirt.bandcamp.com/" target="_blank" rel="noopener">Bandcamp</a>
		</div>
		<p class="copyright">&copy; {today.getFullYear()} in the blue shirt</p>
	</div>
</footer>

<style>
	footer {
		margin-top: 4rem;
		border-top: 1px solid var(--border);
		background: var(--bg-soft);
	}
	.footer-inner {
		max-width: 960px;
		margin: 0 auto;
		padding: 2.5rem 1.5rem;
		text-align: center;
	}
	.footer-links {
		display: flex;
		justify-content: center;
		gap: 1.5em;
		margin-bottom: 1em;
		flex-wrap: wrap;
	}
	.footer-links a {
		font-size: 0.85em;
		color: var(--text-light);
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.footer-links a:hover {
		color: var(--accent);
	}
	.copyright {
		font-size: 0.8em;
		color: var(--text-light);
		margin: 0;
	}
</style>
