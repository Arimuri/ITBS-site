---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

// Fetch YouTube playlist RSS feeds
async function fetchPlaylist(playlistId: string) {
	try {
		const res = await fetch(`https://www.youtube.com/feeds/videos.xml?playlist_id=${playlistId}`);
		const xml = await res.text();
		const entries = xml.match(/<entry>([\s\S]*?)<\/entry>/g) || [];
		return entries.map((entry) => {
			const videoId = entry.match(/<yt:videoId>(.*?)<\/yt:videoId>/)?.[1] ?? '';
			const title = entry.match(/<media:title>(.*?)<\/media:title>/)?.[1]
				?? entry.match(/<title>(.*?)<\/title>/)?.[1] ?? '';
			return { videoId, title };
		});
	} catch { return []; }
}

const playlist1 = await fetchPlaylist('PLNdj0Iz_UsvPDvPgyDfii0qix4aHPaa_1');
const playlist2 = await fetchPlaylist('PLNdj0Iz_UsvMTLJxFynqiRLgM75kh1ugp');
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="hero animate-in">
				<img src="/logo.png" alt="in the blue shirt" class="hero-logo" />
				<p class="hero-desc">音楽と映像を楽しく作っています！</p>
				<p class="hero-desc-en">I enjoy making music and videos!</p>
				<div class="social-icons">
					<a href="https://twitter.com/intheblueshirt" target="_blank" rel="noopener" aria-label="Twitter">
						<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
					</a>
					<a href="https://www.instagram.com/intheblueshirt/" target="_blank" rel="noopener" aria-label="Instagram">
						<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
					</a>
					<a href="https://www.youtube.com/@intheblueshirt" target="_blank" rel="noopener" aria-label="YouTube">
						<svg viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
					</a>
					<a href="https://intheblueshirt.bandcamp.com/" target="_blank" rel="noopener" aria-label="Bandcamp">
						<svg viewBox="0 0 24 24" fill="currentColor"><path d="M0 18.75l7.437-13.5H24l-7.438 13.5z"/></svg>
					</a>
				</div>
			</section>

			<!-- Playlists -->
			{[
				{ title: "Music Videos", videos: playlist2 },
				{ title: "Free Association", videos: playlist1 },
			].map((pl) => pl.videos.length > 0 && (
				<section class="video-section animate-in">
					<h2 class="section-title">{pl.title}</h2>
					<div class="video-scroll">
						{pl.videos.map((v) => (
							<a class="video-card" href={`https://www.youtube.com/watch?v=${v.videoId}`} target="_blank" rel="noopener">
								<div class="video-thumb">
									<img src={`https://i.ytimg.com/vi/${v.videoId}/mqdefault.jpg`} alt={v.title} loading="lazy" />
									<div class="play-icon">
										<svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
									</div>
								</div>
								<p class="video-title">{v.title}</p>
							</a>
						))}
					</div>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		padding-top: 8rem;
		max-width: 100%;
		overflow-x: hidden;
	}
	/* Hero */
	.hero {
		text-align: center;
		padding: 3rem 0 4rem;
		max-width: 960px;
		margin: 0 auto;
		padding-left: 1.5rem;
		padding-right: 1.5rem;
	}
	.hero-logo {
		display: block;
		width: 100%;
		max-width: 520px;
		height: auto;
		margin: 0 auto 1.5em;
		border-radius: 0;
	}
	.hero-desc {
		font-size: 1.1em;
		color: var(--text-light);
		margin-bottom: 0.3em;
	}
	.hero-desc-en {
		font-size: 0.95em;
		color: var(--text-light);
		margin-bottom: 2em;
	}

	/* Social Icons */
	.social-icons {
		display: flex;
		justify-content: center;
		gap: 1.2em;
		margin-top: 1em;
	}
	.social-icons a {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 56px;
		height: 56px;
		color: var(--accent);
		transition: color 0.2s ease, transform 0.2s ease;
	}
	.social-icons a:hover {
		color: var(--accent);
		transform: translateY(-2px);
	}
	.social-icons svg {
		width: 52px;
		height: 52px;
	}

	/* Video Sections */
	.video-section {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5rem 2.5rem;
	}
	.section-title {
		font-size: 1.1em;
		margin-bottom: 1em;
		letter-spacing: -0.01em;
	}
	.video-scroll {
		display: flex;
		gap: 1em;
		overflow-x: auto;
		scroll-snap-type: x mandatory;
		-webkit-overflow-scrolling: touch;
		padding-bottom: 0.5em;
		scrollbar-width: thin;
		scrollbar-color: var(--border) transparent;
	}
	.video-scroll::-webkit-scrollbar {
		height: 6px;
	}
	.video-scroll::-webkit-scrollbar-track {
		background: transparent;
	}
	.video-scroll::-webkit-scrollbar-thumb {
		background: var(--border);
		border-radius: 3px;
	}
	.video-card {
		flex: 0 0 260px;
		scroll-snap-align: start;
		text-decoration: none;
		color: var(--text);
		transition: transform 0.2s ease;
	}
	.video-card:hover {
		transform: translateY(-3px);
		color: var(--text);
	}
	.video-thumb {
		position: relative;
		border-radius: var(--radius);
		overflow: hidden;
		aspect-ratio: 16 / 9;
		background: #000;
	}
	.video-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		border-radius: 0;
		transition: opacity 0.2s ease;
	}
	.play-icon {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: rgba(0, 0, 0, 0.25);
		opacity: 0;
		transition: opacity 0.2s ease;
	}
	.play-icon svg {
		width: 40px;
		height: 40px;
		color: #fff;
	}
	.video-card:hover .play-icon {
		opacity: 1;
	}
	.video-title {
		font-size: 0.8em;
		margin: 0.6em 0 0;
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	@media (max-width: 640px) {
		.hero-logo { max-width: 320px; }
		.video-card { flex: 0 0 200px; }
	}
</style>
