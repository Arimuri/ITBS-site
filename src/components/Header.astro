---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo">{SITE_TITLE}</a>
		<button class="menu-toggle" aria-label="メニューを開く" aria-expanded="false">
			<span></span>
			<span></span>
		</button>
		<div class="nav-links">
			<HeaderLink href="/">home</HeaderLink>
			<HeaderLink href="/biography">biography</HeaderLink>
			<HeaderLink href="/release">release</HeaderLink>
			<HeaderLink href="/works">works</HeaderLink>
			<HeaderLink href="/schedule">schedule</HeaderLink>
			<HeaderLink href="/blog">blog</HeaderLink>
			<HeaderLink href="/contact">contact</HeaderLink>
			<a href="https://shop.intheblueshirt.com/" target="_blank" rel="noopener">shop</a>
		</div>
	</nav>
</header>

<style>
	header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: rgba(255, 255, 255, 0.85);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border-light);
	}
	nav {
		max-width: 960px;
		margin: 0 auto;
		padding: 0 1.5rem;
		height: 60px;
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.logo {
		font-size: 1.1em;
		font-weight: 700;
		color: var(--text);
		text-decoration: none;
		letter-spacing: -0.02em;
	}
	.logo:hover {
		color: var(--accent);
	}
	.nav-links {
		display: flex;
		align-items: center;
		gap: 2em;
	}
	.nav-links :global(a) {
		font-size: 0.85em;
		font-weight: 500;
		color: var(--text-light);
		text-decoration: none;
		transition: color 0.2s ease;
		letter-spacing: 0.02em;
	}
	.nav-links :global(a:hover),
	.nav-links :global(a.active) {
		color: var(--accent);
	}
	.nav-links :global(a.active) {
		font-weight: 700;
	}
	.menu-toggle {
		display: none;
		flex-direction: column;
		gap: 5px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 4px;
	}
	.menu-toggle span {
		display: block;
		width: 22px;
		height: 2px;
		background: var(--text);
		border-radius: 1px;
		transition: 0.2s ease;
	}
	@media (max-width: 640px) {
		.menu-toggle {
			display: flex;
		}
		.nav-links {
			display: none;
			position: absolute;
			top: 60px;
			left: 0;
			right: 0;
			background: rgba(255, 255, 255, 0.95);
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
			flex-direction: column;
			padding: 1em 1.5rem 1.5em;
			gap: 0.8em;
			border-bottom: 1px solid var(--border);
		}
		.nav-links.open {
			display: flex;
		}
	}
</style>

<script>
	const toggle = document.querySelector('.menu-toggle');
	const links = document.querySelector('.nav-links');
	if (toggle && links) {
		toggle.addEventListener('click', () => {
			const isOpen = links.classList.toggle('open');
			toggle.setAttribute('aria-expanded', String(isOpen));
		});
	}
</script>
