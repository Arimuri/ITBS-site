---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, date, updatedDate, heroImage } = Astro.props;
const displayDate = pubDate ?? date;
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main>
			<article class="animate-in">
				{heroImage && (
					<div class="hero-image">
						<Image width={960} height={480} src={heroImage} alt="" />
					</div>
				)}
				<div class="article-header">
					<p class="article-date">
						<FormattedDate date={displayDate} />
						{updatedDate && (
							<span class="updated"> (updated: <FormattedDate date={updatedDate} />)</span>
						)}
					</p>
					<h1>{title}</h1>
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
	}
	.hero-image {
		margin-bottom: 2em;
	}
	.hero-image :global(img) {
		width: 100%;
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-md);
	}
	.article-header {
		margin-bottom: 2em;
	}
	.article-date {
		font-size: 0.85em;
		color: var(--text-light);
		margin-bottom: 0.5em;
	}
	.updated {
		font-style: italic;
	}
	.article-header h1 {
		font-size: 2em;
		letter-spacing: -0.02em;
		line-height: 1.3;
	}
	.prose {
		line-height: 1.9;
	}
	.prose :global(h2) {
		margin-top: 2em;
	}
	.prose :global(h3) {
		margin-top: 1.5em;
	}
	.prose :global(img) {
		border-radius: var(--radius);
		margin: 1.5em 0;
	}
</style>
